{
  "expo": {
    "name": "SwingSense",
    "slug": "SwingSense",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "backgroundColor": "#0f172a",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "buildNumber": "3",
      "supportsTablet": true,
      "backgroundColor": "#0f172a",
      "bundleIdentifier": "com.jwallvtgc.swingsense",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "SwingSense needs access to your photo library to select swing videos.",
        "NSCameraUsageDescription": "SwingSense needs camera access to record your swing.",
        "NSMicrophoneUsageDescription": "SwingSense needs microphone access to record video with audio.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.jwallvtgc.swingsense",
      "adaptiveIcon": {
        "backgroundColor": "#1B4D3E",
        "foregroundImage": "./assets/icon.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "backgroundColor": "#0f172a",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 500,
          "backgroundColor": "#0f172a"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SwingSense needs access to your photo library to select swing videos.",
          "cameraPermission": "SwingSense needs camera access to record your swing."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "SwingSense needs camera access to record your swing.",
          "microphonePermission": "SwingSense needs microphone access to record video with audio.",
          "recordAudioAndroid": {
            "default": true
          }
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "be4f3253-ce54-488b-b457-f2d3900dfbc8"
      }
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/be4f3253-ce54-488b-b457-f2d3900dfbc8"
    }
  }
}
