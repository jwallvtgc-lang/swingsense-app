{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "channel": "preview",
      "env": {
        "XDG_CACHE_HOME": "/tmp/.cache",
        "TMPDIR": "/tmp",
        "EXPO_IMAGE_UTILS_NO_SHARP": "1"
      }
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "XDG_CACHE_HOME": "/tmp/.cache"
      }
    },
    "production": {
      "channel": "production",
      "env": {
        "XDG_CACHE_HOME": "/tmp/.cache"
      }
    }
  }
}
